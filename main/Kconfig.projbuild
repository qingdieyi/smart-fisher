# ═══════════════════════════════════════════════════════════════════
# 项目配置菜单 — Kconfig.projbuild
#
# ── 这是什么？ ───────────────────────────────────────────────────
#
# Kconfig 是 Linux 内核使用的配置系统，ESP-IDF 继承了它。
# 这个文件定义了运行 `idf.py menuconfig` 时看到的配置界面。
#
# ── 给 Java 开发者 ───────────────────────────────────────────────
#
#   Java 概念                       Kconfig 对应
#   ──────────────────────────────────────────────────────────────
#   application.yml 中的配置项       Kconfig 中的 config 项
#   配置项的类型（String/int/bool）  Kconfig 的 string/int/bool 关键字
#   @ConfigurationProperties        menuconfig 界面的菜单
#   配置项的 default 值              default 关键字
#   IDE 的配置提示                   help 块
#
# ── 怎么用 ───────────────────────────────────────────────────────
#
#   1. 运行 `idf.py menuconfig`
#   2. 进入 "Smart Fisher Configuration" 菜单
#   3. 修改 SSID、密码、检测方式等
#   4. 保存退出 → 自动生成 sdkconfig 文件
#
#   注意：sdkconfig 是运行时生成的，不要手动编辑。
#   如果要设默认值，改 sdkconfig.defaults 文件。
#
# ═══════════════════════════════════════════════════════════════════

menu "Smart Fisher Configuration"
    # menu = 创建一个菜单子项（类似配置页面的一个 tab）

    # ── WiFi 配置 ──────────────────────────────────────────────

    config SMART_FISHER_WIFI_SSID
        string "WiFi SSID"
        # config 定义一个配置项
        # string = 值的类型是字符串
        # "WiFi SSID" = 在菜单中显示的标签
        default "yang"
        # default = 默认值（当 sdkconfig 中还没有这个配置项时使用）
        help
            SSID (network name) for the Smart Fisher to connect to.

    config SMART_FISHER_WIFI_PASSWORD
        string "WiFi Password"
        default "yang123456"
        help
            WiFi password (WPA2-PSK).

    # ── 鱼群检测方式选择 ──────────────────────────────────────

    choice SMART_FISHER_DETECTION_METHOD
        prompt "Fish Detection Method"
        default SMART_FISHER_DETECTION_FRAME_DIFF
        help
            Select the algorithm used to detect fish in the aquarium.

            Frame Differencing:
              - Fast (~80ms), low memory (~40KB)
              - Detects movement only (can miss stationary fish)
              - No external dependencies or model files needed
              - Good for: getting started, resource-constrained setups

            YOLO Object Detection (ESP-DL):
              - Neural network-based, can detect fish even when stationary
              - Memory: ~700KB PSRAM, ~500KB Flash (model weights)
              - Requires: trained .espdl model file placed in main/models/
              - Good for: accurate counting, species identification

        config SMART_FISHER_DETECTION_FRAME_DIFF
            bool "Frame Differencing (motion-based)"
            help
                Simple motion detection using pixel comparison between
                consecutive frames. Detects movement regions and estimates
                fish count via connected-component analysis.

                Pros: Zero dependencies, fast, low memory.
                Cons: Cannot detect stationary fish; bubbles/water flow
                      may cause false positives.

        config SMART_FISHER_DETECTION_YOLO
            bool "YOLO Object Detection (ESP-DL neural network)"
            help
                Deep learning based fish detection using YOLO architecture
                running on ESP-DL inference engine.

                Prerequisites:
                  1. Trained .espdl model file placed at:
                     main/models/espdet_pico_fish.espdl
                  2. ESP-DL component added to idf_component.yml:
                     espressif/esp-dl: "^3.3.0"

                Training guide: docs/yolo-practical-guide.md
                Architecture plan: docs/esp-dl-yolo-plan.md
    endchoice

    # ── YOLO 相关配置（仅在选择 YOLO 时可见） ──────────────────

    config SMART_FISHER_YOLO_MODEL_PATH
        string "YOLO Model File Path"
        depends on SMART_FISHER_DETECTION_YOLO
        default "main/models/espdet_pico_fish.espdl"
        help
            Path to the .espdl model file, relative to the project root.
            This file is generated by the esp-detection training pipeline.

    config SMART_FISHER_YOLO_CONFIDENCE_THRESHOLD
        float "YOLO Confidence Threshold"
        depends on SMART_FISHER_DETECTION_YOLO
        default 0.50
        range 0.10 0.95
        help
            Minimum confidence score for a detection to be considered valid.
            Lower values = more detections (may include false positives).
            Higher values = fewer detections (may miss real fish).
            Recommended: 0.40 ~ 0.60

    config SMART_FISHER_YOLO_IOU_THRESHOLD
        float "YOLO NMS IoU Threshold"
        depends on SMART_FISHER_DETECTION_YOLO
        default 0.45
        range 0.20 0.80
        help
            Intersection-over-Union threshold for Non-Maximum Suppression.
            Controls how much overlap is allowed between detected boxes.
            Lower values = more aggressive merging.
            Recommended: 0.40 ~ 0.50

endmenu
